# ================================================================
# The Postgraduate Data Hub Kenya — environment variables template
# Copy this file to `.env` and fill in the real values.
# ================================================================

# Backend selection:
#   'local'    = data lives in each browser's localStorage (no cloud)
#   'supabase' = data lives in Supabase cloud (recommended for production)
VITE_BACKEND=supabase

# ---- Only needed when VITE_BACKEND=supabase ----
# Find these in your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
