# Dependencies — regenerated by `npm install`, never commit
node_modules/

# Build output — regenerated by `npm run build`, never commit
dist/
build/
.vite/

# Environment variables — LOCAL developer-only versions
# NOTE: .env IS committed here because it contains only public anon keys.
# If you ever add secret keys, move them to .env.local (which IS ignored).
.env.local
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
coverage/
.nyc_output/

# Backup folder (not needed on GitHub)
postgrad-hub-BACKUP/
